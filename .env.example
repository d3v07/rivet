# Google Gemini API (option 1: API key from AI Studio)
GEMINI_API_KEY=

# Google Cloud Platform (option 2: Vertex AI uses GCP_PROJECT_ID)
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./sa-key.json

# Jira Configuration
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ

# MCP Server
MCP_TRANSPORT=stdio
MCP_HOST=localhost
MCP_PORT=3000

# GitLab
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=

# Feature Flags
RIVET_DRY_RUN=false
RIVET_SECURITY_STRICT=true
