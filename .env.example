# Ollama (local, free — preferred for development)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Google Gemini API (option 2: API key from AI Studio)
GEMINI_API_KEY=

# Anthropic Claude API (option 3: for Anthropic prize track)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Cloud Platform (option 4: Vertex AI uses GCP_PROJECT_ID)
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./sa-key.json

# Jira Configuration
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ

# MCP Server
MCP_TRANSPORT=stdio
MCP_HOST=localhost
MCP_PORT=3000

# GitLab
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=

# Feature Flags
RIVET_DRY_RUN=false
RIVET_SECURITY_STRICT=true
